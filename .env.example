# ============================================================
# DiaMerna — Environment Variables
# ============================================================
# For LOCAL development, set these in your terminal before
# running: node serve.js
#
# For VERCEL deployment, set these in Vercel dashboard:
# Settings → Environment Variables

# Dropbox OAuth (required for cloud backup)
# Get from: https://www.dropbox.com/developers/apps
DROPBOX_CLIENT_ID=your_dropbox_app_key
DROPBOX_CLIENT_SECRET=your_dropbox_app_secret

# OAuth Redirect URI (for Vercel, set to your deployment URL)
# OAUTH_REDIRECT_URI=https://your-app.vercel.app/api/oauth/callback

# JWT Secret (optional — auto-generated if not set)
# JWT_SECRET=your-random-secret-here
