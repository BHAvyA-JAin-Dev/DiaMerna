# ============================================================
# DiaMerna — Dropbox OAuth Credentials (required)
# ============================================================
# Set these before starting the server. Users will see a
# "Connect to Dropbox" button that uses OAuth 2.0 flow.
#
# How to get these:
# 1. Go to https://www.dropbox.com/developers/apps
# 2. Select your "DiaMerna" app (or create one)
# 3. App folder type → "DiaMerna"
# 4. Under "OAuth 2" → Add redirect URI:
#    http://localhost:5500/api/oauth/callback
# 5. Copy the "App key" and "App secret"
#
# On Windows (PowerShell):
#   $env:DROPBOX_CLIENT_ID = "your_app_key"
#   $env:DROPBOX_CLIENT_SECRET = "your_app_secret"
#   node serve.js
#
# On macOS/Linux:
#   DROPBOX_CLIENT_ID="your_app_key" \
#   DROPBOX_CLIENT_SECRET="your_app_secret" \
#   node serve.js

DROPBOX_CLIENT_ID=your_dropbox_app_key
DROPBOX_CLIENT_SECRET=your_dropbox_app_secret
